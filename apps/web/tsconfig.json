{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "preserve",
    "lib": ["dom", "dom.iterable", "es2022"],
    "module": "esnext",
    "allowJs": false,
    "incremental": true,
    "paths": {
      "@arka/shared": ["../../packages/shared/src/index.ts"],
      "@arka/shared/*": ["../../packages/shared/src/*"],
      "@arka/core": ["../../packages/core/src/index.ts"],
      "@arka/core/*": ["../../packages/core/src/*"],
      "@arka/agent": ["../../packages/agent/src/index.ts"],
      "@arka/agent/*": ["../../packages/agent/src/*"],
      "@arka/db": ["../../packages/db/src/index.ts"],
      "@arka/db/*": ["../../packages/db/src/*"]
    },
    "plugins": [{ "name": "next" }]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
