{
  "name": "@arka/db",
  "private": true,
  "version": "0.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@arka/shared": "workspace:*",
    "drizzle-orm": "latest",
    "pg": "latest"
  },
  "devDependencies": {
    "drizzle-kit": "latest",
    "typescript": "latest"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate": "drizzle-kit generate --config drizzle.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
