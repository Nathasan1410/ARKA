{
  "name": "arka-monorepo",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "pnpm --filter @arka/web dev",
    "dev:web": "pnpm --filter @arka/web dev",
    "build": "pnpm -r --if-present run build",
    "build:web": "pnpm --filter @arka/web build",
    "typecheck": "pnpm --filter @arka/shared --filter @arka/core --filter @arka/agent run typecheck",
    "lint": "pnpm -r --if-present run lint",
    "clean": "pnpm -r --if-present run clean"
  }
}
